{
  "expo": {
    "name": "Followup",
    "slug": "followup",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "followup",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sjseto.followup"
    },
    "android": {
      "package": "com.sjseto.followup",
      "adaptiveIcon": {
        "backgroundColor": "#1a2332",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#1a2332"
        }
      ],
      "expo-sharing",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Followup uses the microphone so you can speak your observations instead of typing them.",
          "speechRecognitionPermission": "Followup uses speech recognition to turn your spoken observations into text. Audio may be processed by your device's speech service."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
